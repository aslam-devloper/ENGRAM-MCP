# ENGRAM config — copy to .env (optional, not required for basic use)

# Override where ENGRAM stores all memory (default: ~/.engram)
# ENGRAM_HOME=/Users/you/.engram

# Team shared brain — point everyone to the same folder:
# ENGRAM_HOME=/shared/team/.engram

# Inside a repo (commits memory with code):
# ENGRAM_HOME=./.engram
